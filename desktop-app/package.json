{
  "name": "applicationversion1",
  "version": "1.0.0",
  "description": "Cabinet Maitre Araqi Houssaini offline desktop app",
  "main": "main.js",
  "author": "Cabinet Maitre Araqi Houssaini",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --x64",
    "build:win": "electron-builder --win portable --x64",
    "build:win:portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.applicationversion1.offline",
    "productName": "Cabinet Maitre Araqi Houssaini",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "offline-web/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "applicationversion1-${version}.${ext}"
    }
  }
}
